{
  "name": "puntual",
  "private": true,
  "version": "0.1.9",
  "license": "AGPL-3.0-or-later",
  "description": "Puntual, alarma de escritorio para Linux con bandeja del sistema y persistencia real.",
  "homepage": "https://github.com/jjdeharo/puntual",
  "repository": {
    "type": "git",
    "url": "git@github.com:jjdeharo/puntual.git"
  },
  "author": {
    "name": "Juan Jose de Haro",
    "email": "jjdeharo@gmail.com"
  },
  "desktopName": "io.jjdeharo.puntual.desktop",
  "main": "electron/main.mjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc -b && vite build",
    "start": "electron .",
    "dist:app": "npm run build && electron-builder --linux dir",
    "dist:release": "npm run build && electron-builder --publish never",
    "dist": "npm run build && electron-builder --linux deb",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/manrope": "^5.2.8",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "io.jjdeharo.puntual",
    "productName": "Puntual",
    "compression": "normal",
    "files": [
      "dist/renderer/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "linux": {
      "target": [
        "deb",
        "dir",
        "AppImage"
      ],
      "category": "Utility",
      "maintainer": "Juan Jose de Haro <jjdeharo@gmail.com>"
    },
    "win": {
      "target": [
        "portable",
        "zip"
      ]
    },
    "mac": {
      "target": [
        "zip"
      ],
      "category": "public.app-category.productivity"
    }
  }
}
